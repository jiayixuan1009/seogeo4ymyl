# 复制为 .env 后填写；.env 已被 Git 忽略，勿提交真实密钥。
# Copy to .env and fill in; .env is gitignored — never commit secrets.

PORT=3000

# 反向代理后需要限流等场景可保持默认；本机直连调试可设为 0
# Keep default behind nginx; set 0 for local direct access if needed.
# TRUST_PROXY=0

NODE_ENV=development

# OpenAI 兼容接口用的服务端密钥（勿提交）
# Server-side key for OpenAI-compatible proxy (never commit).
LLM_API_KEY=

# 逗号分隔的额外允许主机名（小写），用于 SSRF 白名单扩展
# Extra allowed LLM API hostnames (comma-separated, lowercase).
# LLM_ALLOWED_HOSTS_EXTRA=
